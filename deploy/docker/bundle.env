# Delivery bundle runtime defaults.
# Edit this file before startup when you need to change port or intranet tile settings.

STUDIO_IMAGE_TAG=trajectory-annotation-studio-offline:latest
STUDIO_CONTAINER_NAME=trajectory-annotation-studio
HOST_STUDIO_PORT=8016

# offline | intranet | online
STUDIO_TILE_DEFAULT_MODE=online

# Supports both XYZ path and query-string templates, for example:
# http://host/styles/basic/{z}/{x}/{y}.png
# http://host/tiles?x={x}&y={y}&z={z}
STUDIO_TILE_INTRANET_URL=http://192.110.14.224:8077/styles/basic/{z}/{x}/{y}.png
STUDIO_TILE_INTRANET_ATTRIBUTION=© Map data © OpenStreetMap contributors | Tiles © MapTiler
STUDIO_TILE_INTRANET_COORDINATE_SYSTEM=wgs84
STUDIO_TILE_INTRANET_MIN_ZOOM=3
STUDIO_TILE_INTRANET_MAX_NATIVE_ZOOM=19
STUDIO_TILE_INTRANET_MAX_ZOOM=19
STUDIO_TILE_INTRANET_DETECT_RETINA=1

STUDIO_SIGNAL6_PIPELINE_MODE=v311
